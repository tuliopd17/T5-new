# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
/env*
!/.env*.erb

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key

# Database files
*.sqlite3
*.sqlite3-*
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-wal
/storage/*.sqlite3

# Logs
/log/*.log
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
node_modules/
bower_components/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test
.env.local
.env.production

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Rails specific
/config/database.yml
/config/secrets.yml
/config/credentials.yml.enc
/config/master.key
/config/application.yml

# Ignore uploaded files in development
/public/uploads
/public/system

# Ignore precompiled assets
/public/assets/
/app/assets/builds/

# Ignore cached gems
vendor/bundle/
vendor/cache/

# Ignore Spring files
/spring/*.pid

# Ignore byebug history
.byebug_history

# Ignore error log created by lograge and Rails
/log/*

# Ignore test reports
/coverage.data
/coverage/

# Capybara screenshots
/tmp/screenshots/

# RSpec files
spec/examples.txt

# Ignore Vagrant files
.vagrant/

# Ignore Docker files (if using Docker)
.dockerignore

# Ignore RubyMine files
/.idea

# Ignore VS Code files
/.vscode

# Ignore backup files
*.backup
*.bak
*.orig

# Ignore any secret or sensitive files
secrets.*
*.pem
*.key
*.crt

# Ignore local configuration files
/config/local.yml
/config/settings.local.yml
/config/environments/*.local.yml
