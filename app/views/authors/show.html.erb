<% content_for :title, @author.name %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">
    <i class="fas fa-user-edit me-2"></i>
    <%= @author.name %>
  </h1>
  <div>
    <%= link_to authors_path, class: "btn btn-outline-secondary me-2" do %>
      <i class="fas fa-arrow-left me-2"></i>Voltar
    <% end %>
    <% if current_user&.admin? %>
      <%= link_to edit_author_path(@author), class: "btn btn-primary" do %>
        <i class="fas fa-edit me-2"></i>Editar
      <% end %>
    <% end %>
  </div>
</div>

<div class="row">
  <div class="col-md-8">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">
          <i class="fas fa-info-circle me-2"></i>
          Informações do Autor
        </h5>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-sm-4">
            <strong>Nome:</strong>
          </div>
          <div class="col-sm-8">
            <%= @author.name %>
          </div>
        </div>
        <hr>
        
        <% if @author.birth_date %>
          <div class="row">
            <div class="col-sm-4">
              <strong>Data de Nascimento:</strong>
            </div>
            <div class="col-sm-8">
              <%= @author.birth_date.strftime('%d/%m/%Y') %>
            </div>
          </div>
          <hr>
        <% end %>
        
        <% if @author.nationality.present? %>
          <div class="row">
            <div class="col-sm-4">
              <strong>Nacionalidade:</strong>
            </div>
            <div class="col-sm-8">
              <i class="fas fa-flag me-2"></i><%= @author.nationality %>
            </div>
          </div>
          <hr>
        <% end %>
        
        <% if @author.biography.present? %>
          <div class="row">
            <div class="col-sm-4">
              <strong>Biografia:</strong>
            </div>
            <div class="col-sm-8">
              <%= simple_format(@author.biography) %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">
          <i class="fas fa-book me-2"></i>
          Livros do Autor
        </h5>
      </div>
      <div class="card-body">
        <% if @author.books.any? %>
          <% @author.books.each do |book| %>
            <div class="d-flex align-items-center mb-3">
              <div class="flex-grow-1">
                <%= link_to book.title, book_path(book), class: "text-decoration-none fw-bold" %>
                <% if book.publication_date %>
                  <small class="text-muted d-block">
                    <%= book.publication_date.year %>
                  </small>
                <% end %>
              </div>
              <span class="badge bg-<%= book.available? ? 'success' : 'warning' %>">
                <%= book.available? ? 'Disponível' : 'Emprestado' %>
              </span>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted text-center">
            <i class="fas fa-book-open fa-2x mb-2 d-block"></i>
            Nenhum livro cadastrado para este autor.
          </p>
        <% end %>
      </div>
    </div>
  </div>
</div>
