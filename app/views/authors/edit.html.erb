<% content_for :title, "Editar #{@author.name}" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">
    <i class="fas fa-user-edit me-2"></i>
    Editar Autor
  </h1>
  <div>
    <%= link_to author_path(@author), class: "btn btn-outline-secondary me-2" do %>
      <i class="fas fa-arrow-left me-2"></i>Voltar
    <% end %>
    <% if current_user&.admin? %>
      <%= button_to author_path(@author), method: :delete,
          form: { data: { turbo_confirm: "Tem certeza que deseja excluir este autor?" } },
          class: "btn btn-outline-danger" do %>
        <i class="fas fa-trash me-2"></i>Excluir
      <% end %>
    <% end %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <%= form_with model: @author, local: true, class: "needs-validation", novalidate: true do |f| %>
      <% if @author.errors.any? %>
        <div class="alert alert-danger">
          <h5><i class="fas fa-exclamation-triangle me-2"></i>Erro ao salvar autor:</h5>
          <ul class="mb-0">
            <% @author.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="row">
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :name, "Nome", class: "form-label" %>
            <%= f.text_field :name, class: "form-control", required: true %>
            <div class="invalid-feedback">
              Por favor, informe o nome do autor.
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :nationality, "Nacionalidade", class: "form-label" %>
            <%= f.text_field :nationality, class: "form-control" %>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :birth_date, "Data de Nascimento", class: "form-label" %>
            <%= f.date_field :birth_date, class: "form-control" %>
          </div>
        </div>
      </div>

      <div class="mb-3">
        <%= f.label :biography, "Biografia", class: "form-label" %>
        <%= f.text_area :biography, class: "form-control", rows: 4 %>
        <div class="form-text">Informações sobre a vida e obra do autor.</div>
      </div>

      <div class="d-flex justify-content-end gap-2">
        <%= link_to author_path(@author), class: "btn btn-secondary" do %>
          <i class="fas fa-times me-2"></i>Cancelar
        <% end %>
        <%= f.submit "Atualizar Autor", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
