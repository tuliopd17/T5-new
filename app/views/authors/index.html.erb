<% content_for :title, "Autores" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">
    <i class="fas fa-user-edit me-2"></i>
    Autores
  </h1>
  <% if current_user&.admin? %>
    <%= link_to new_author_path, class: "btn btn-primary" do %>
      <i class="fas fa-plus me-2"></i>Novo Autor
    <% end %>
  <% end %>
</div>

<div class="card">
  <div class="card-body">
    <% if @authors.any? %>
      <div class="row">
        <% @authors.each do |author| %>
          <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100">
              <div class="card-body">
                <h5 class="card-title">
                  <%= link_to author.name, author_path(author), class: "text-decoration-none" %>
                </h5>
                <p class="card-text">
                  <small class="text-muted">
                    <i class="fas fa-flag me-1"></i><%= author.nationality %>
                  </small>
                </p>
                <% if author.birth_date %>
                  <p class="card-text">
                    <small class="text-muted">
                      <i class="fas fa-birthday-cake me-1"></i>
                      <%= author.birth_date.strftime('%d/%m/%Y') %>
                    </small>
                  </p>
                <% end %>
                <% if author.biography.present? %>
                  <p class="card-text">
                    <%= truncate(author.biography, length: 100) %>
                  </p>
                <% end %>
              </div>
              <div class="card-footer bg-transparent">
                <div class="btn-group w-100" role="group">
                  <%= link_to author_path(author), class: "btn btn-outline-primary btn-sm" do %>
                    <i class="fas fa-eye"></i>
                  <% end %>
                  <% if current_user&.admin? %>
                    <%= link_to edit_author_path(author), class: "btn btn-outline-warning btn-sm" do %>
                      <i class="fas fa-edit"></i>
                    <% end %>
                    <%= link_to author_path(author), data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir este autor?" },
                        class: "btn btn-outline-danger btn-sm" do %>
                      <i class="fas fa-trash"></i>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="fas fa-user-edit fa-3x text-muted mb-3"></i>
        <h4 class="text-muted">Nenhum autor encontrado</h4>
        <p class="text-muted">Cadastre o primeiro autor do sistema.</p>
        <% if current_user&.admin? %>
          <%= link_to new_author_path, class: "btn btn-primary" do %>
            <i class="fas fa-plus me-2"></i>Cadastrar Autor
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
