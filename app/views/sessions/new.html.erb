<% content_for :title, "Login" %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-4">
    <div class="card shadow">
      <div class="card-header bg-primary text-white text-center">
        <h4><i class="fas fa-sign-in-alt"></i> Login</h4>
      </div>
      <div class="card-body">
        <%= form_with url: login_path, local: true, data: { turbo: false }, class: "needs-validation", novalidate: true do |form| %>
          <div class="mb-3">
            <%= form.label :email, class: "form-label" %>
            <%= form.email_field :email, class: "form-control", required: true, autofocus: true %>
            <div class="invalid-feedback">
              Por favor, insira um email válido.
            </div>
          </div>

          <div class="mb-3">
            <%= form.label :password, "Senha", class: "form-label" %>
            <%= form.password_field :password, class: "form-control", required: true %>
            <div class="invalid-feedback">
              Por favor, insira sua senha.
            </div>
          </div>

          <div class="d-grid">
            <%= form.submit "Entrar", class: "btn btn-primary" %>
          </div>
        <% end %>

        <hr>
        <div class="text-center">
          <p class="mb-0">Não tem uma conta?</p>
          <%= link_to "Registrar-se", new_user_path, class: "btn btn-outline-secondary btn-sm" %>
        </div>
        
        <% if Rails.env.development? %>
          <hr>
          <div class="alert alert-info small">
            <strong>Credenciais para teste:</strong><br>
            <strong>Admin:</strong> admin@biblioteca.com / 123456<br>
            <strong>Usuário:</strong> usuario@biblioteca.com / 123456
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
// Validação de formulário Bootstrap
(function() {
  'use strict';
  window.addEventListener('load', function() {
    var forms = document.getElementsByClassName('needs-validation');
    var validation = Array.prototype.filter.call(forms, function(form) {
      form.addEventListener('submit', function(event) {
        if (form.checkValidity() === false) {
          event.preventDefault();
          event.stopPropagation();
        }
        form.classList.add('was-validated');
      }, false);
    });
  }, false);
})();
</script>
