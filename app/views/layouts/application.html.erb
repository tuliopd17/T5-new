<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Biblioteca Digital" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-light">
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
      <div class="container">
        <%= link_to "📚 Biblioteca Digital", root_path, class: "navbar-brand fw-bold" %>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <% if logged_in? %>
              <li class="nav-item">
                <%= link_to "Livros", books_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Autores", authors_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Categorias", categories_path, class: "nav-link" %>
              </li>
              <% if current_user.admin? %>
                <li class="nav-item">
                  <%= link_to "Usuários", users_path, class: "nav-link" %>
                </li>
              <% end %>
            <% end %>
          </ul>
          
          <ul class="navbar-nav">
            <% if logged_in? %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                  <i class="fas fa-user"></i> <%= current_user.name %>
                  <% if current_user.admin? %>
                    <span class="badge bg-warning text-dark ms-1">Admin</span>
                  <% end %>
                </a>
                <ul class="dropdown-menu">
                  <li><%= link_to "Meu Perfil", current_user, class: "dropdown-item" %></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><%= link_to "Sair", logout_path, data: { turbo_method: :delete }, class: "dropdown-item" %></li>
                </ul>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "Entrar", login_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Registrar", new_user_path, class: "nav-link" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if flash[:notice] %>
      <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
        <%= flash[:notice] %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>
    
    <% if flash[:alert] %>
      <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
        <%= flash[:alert] %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>

    <!-- Main Content -->
    <div class="container-fluid py-4">
      <%= yield %>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
