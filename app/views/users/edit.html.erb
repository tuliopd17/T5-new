<% content_for :title, "Editar #{@user.name}" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">
    <i class="fas fa-user-edit me-2"></i>
    Editar Usuário
  </h1>
  <div>
    <%= link_to user_path(@user), class: "btn btn-outline-secondary me-2" do %>
      <i class="fas fa-arrow-left me-2"></i>Voltar
    <% end %>
    <% if current_user&.admin? && @user != current_user %>
      <%= button_to user_path(@user), method: :delete,
          form: { data: { turbo_confirm: "Tem certeza que deseja excluir este usuário?" } },
          class: "btn btn-outline-danger" do %>
        <i class="fas fa-trash me-2"></i>Excluir
      <% end %>
    <% end %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <%= form_with model: @user, local: true, class: "needs-validation", novalidate: true do |f| %>
      <% if @user.errors.any? %>
        <div class="alert alert-danger">
          <h5><i class="fas fa-exclamation-triangle me-2"></i>Erro ao salvar usuário:</h5>
          <ul class="mb-0">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="row">
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :name, "Nome", class: "form-label" %>
            <%= f.text_field :name, class: "form-control", required: true %>
            <div class="invalid-feedback">
              Por favor, informe o nome.
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :email, "Email", class: "form-label" %>
            <%= f.email_field :email, class: "form-control", required: true %>
            <div class="invalid-feedback">
              Por favor, informe um email válido.
            </div>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :password, "Nova Senha", class: "form-label" %>
            <%= f.password_field :password, class: "form-control" %>
            <div class="form-text">Deixe em branco para manter a senha atual.</div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :password_confirmation, "Confirmar Nova Senha", class: "form-label" %>
            <%= f.password_field :password_confirmation, class: "form-control" %>
          </div>
        </div>
      </div>

      <% if current_user&.admin? %>
        <div class="mb-3">
          <label class="form-label">Tipo de Usuário</label>
          <div>
            <div class="form-check form-check-inline">
              <%= f.radio_button :role, "user", class: "form-check-input" %>
              <%= f.label :role_user, "Usuário", class: "form-check-label" %>
            </div>
            <div class="form-check form-check-inline">
              <%= f.radio_button :role, "admin", class: "form-check-input" %>
              <%= f.label :role_admin, "Administrador", class: "form-check-label" %>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Perfil do usuário -->
      <h5 class="mt-4 mb-3">
        <i class="fas fa-id-card me-2"></i>
        Informações do Perfil
      </h5>

      <%= f.fields_for :profile do |profile_form| %>
        <div class="row">
          <div class="col-md-6">
            <div class="mb-3">
              <%= profile_form.label :phone, "Telefone", class: "form-label" %>
              <%= profile_form.text_field :phone, class: "form-control" %>
            </div>
          </div>
          <div class="col-md-6">
            <div class="mb-3">
              <%= profile_form.label :avatar_url, "URL do Avatar", class: "form-label" %>
              <%= profile_form.url_field :avatar_url, class: "form-control" %>
            </div>
          </div>
        </div>

        <div class="mb-3">
          <%= profile_form.label :address, "Endereço", class: "form-label" %>
          <%= profile_form.text_area :address, class: "form-control", rows: 2 %>
        </div>

        <div class="mb-3">
          <%= profile_form.label :bio, "Biografia", class: "form-label" %>
          <%= profile_form.text_area :bio, class: "form-control", rows: 3 %>
        </div>
      <% end %>

      <div class="d-flex justify-content-end gap-2">
        <%= link_to user_path(@user), class: "btn btn-secondary" do %>
          <i class="fas fa-times me-2"></i>Cancelar
        <% end %>
        <%= f.submit "Atualizar Usuário", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
