<% content_for :title, "Usuários" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">
    <i class="fas fa-users me-2"></i>
    Usuários
  </h1>
  <%= link_to new_user_path, class: "btn btn-primary" do %>
    <i class="fas fa-user-plus me-2"></i>Novo Usuário
  <% end %>
</div>

<div class="card">
  <div class="card-body">
    <% if @users.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead class="table-dark">
            <tr>
              <th>Nome</th>
              <th>Email</th>
              <th>Tipo</th>
              <th>Empréstimos Ativos</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% @users.each do |user| %>
              <tr>
                <td>
                  <%= link_to user.name, user_path(user), class: "text-decoration-none fw-bold" %>
                </td>
                <td><%= user.email %></td>
                <td>
                  <span class="badge bg-<%= user.admin? ? 'danger' : 'primary' %>">
                    <%= user.admin? ? 'Administrador' : 'Usuário' %>
                  </span>
                </td>
                <td>
                  <% active_loans = user.loans.active.count %>
                  <% if active_loans > 0 %>
                    <span class="badge bg-warning">
                      <%= pluralize(active_loans, 'empréstimo', 'empréstimos') %>
                    </span>
                  <% else %>
                    <span class="text-muted">Nenhum</span>
                  <% end %>
                </td>
                <td>
                  <div class="btn-group" role="group">
                    <%= link_to user_path(user), class: "btn btn-outline-primary btn-sm" do %>
                      <i class="fas fa-eye"></i>
                    <% end %>
                    <% if current_user&.admin? %>
                      <%= link_to edit_user_path(user), class: "btn btn-outline-warning btn-sm" do %>
                        <i class="fas fa-edit"></i>
                      <% end %>
                      <% unless user == current_user %>
                        <%= link_to user_path(user), data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir este usuário?" },
                            class: "btn btn-outline-danger btn-sm" do %>
                          <i class="fas fa-trash"></i>
                        <% end %>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="fas fa-users fa-3x text-muted mb-3"></i>
        <h4 class="text-muted">Nenhum usuário encontrado</h4>
        <p class="text-muted">Cadastre o primeiro usuário do sistema.</p>
        <%= link_to new_user_path, class: "btn btn-primary" do %>
          <i class="fas fa-user-plus me-2"></i>Cadastrar Usuário
        <% end %>
      </div>
    <% end %>
  </div>
</div>
