<% content_for :title, "Editar #{@book.title}" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">
    <i class="fas fa-edit me-2"></i>
    Editar Livro
  </h1>
  <div>
    <%= link_to book_path(@book), class: "btn btn-outline-secondary me-2" do %>
      <i class="fas fa-arrow-left me-2"></i>Voltar
    <% end %>
    <% if current_user&.admin? %>
      <%= button_to book_path(@book), method: :delete,
          form: { data: { turbo_confirm: "Tem certeza que deseja excluir este livro?" } },
          class: "btn btn-outline-danger" do %>
        <i class="fas fa-trash me-2"></i>Excluir
      <% end %>
    <% end %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <%= form_with model: @book, local: true, class: "needs-validation", novalidate: true do |f| %>
      <% if @book.errors.any? %>
        <div class="alert alert-danger">
          <h5><i class="fas fa-exclamation-triangle me-2"></i>Erro ao salvar livro:</h5>
          <ul class="mb-0">
            <% @book.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="row">
        <div class="col-md-8">
          <div class="mb-3">
            <%= f.label :title, "Título", class: "form-label" %>
            <%= f.text_field :title, class: "form-control", required: true %>
            <div class="invalid-feedback">
              Por favor, informe o título do livro.
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="mb-3">
            <%= f.label :isbn, "ISBN", class: "form-label" %>
            <%= f.text_field :isbn, class: "form-control", required: true %>
            <div class="invalid-feedback">
              Por favor, informe o ISBN do livro.
            </div>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :category_id, "Categoria", class: "form-label" %>
            <%= f.collection_select :category_id, @categories, :id, :name, 
                                   { prompt: "Selecione uma categoria" }, 
                                   { class: "form-control", required: true } %>
            <div class="invalid-feedback">
              Por favor, selecione uma categoria.
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="mb-3">
            <%= f.label :publication_date, "Data de Publicação", class: "form-label" %>
            <%= f.date_field :publication_date, class: "form-control" %>
          </div>
        </div>
        <div class="col-md-3">
          <div class="mb-3">
            <%= f.label :pages, "Páginas", class: "form-label" %>
            <%= f.number_field :pages, class: "form-control", min: 1 %>
          </div>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Autores</label>
        <div class="author-checkboxes">
          <%= f.collection_check_boxes :author_ids, @authors, :id, :name do |b| %>
            <div class="form-check form-check-inline">
              <%= b.check_box(class: "form-check-input") %>
              <%= b.label(class: "form-check-label") %>
            </div>
          <% end %>
        </div>
        <small class="form-text text-muted">Selecione um ou mais autores.</small>
      </div>

      <div class="mb-3">
        <%= f.label :description, "Descrição", class: "form-label" %>
        <%= f.text_area :description, class: "form-control", rows: 4 %>
      </div>

      <div class="d-flex justify-content-end gap-2">
        <%= link_to book_path(@book), class: "btn btn-secondary" do %>
          <i class="fas fa-times me-2"></i>Cancelar
        <% end %>
        <%= f.submit "Atualizar Livro", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
