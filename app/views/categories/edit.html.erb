<% content_for :title, "Editar #{@category.name}" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">
    <i class="fas fa-tag me-2"></i>
    Editar Categoria
  </h1>
  <div>
    <%= link_to category_path(@category), class: "btn btn-outline-secondary me-2" do %>
      <i class="fas fa-arrow-left me-2"></i>Voltar
    <% end %>
    <% if current_user&.admin? %>
      <%= button_to category_path(@category), method: :delete,
          form: { data: { turbo_confirm: "Tem certeza que deseja excluir esta categoria?" } },
          class: "btn btn-outline-danger" do %>
        <i class="fas fa-trash me-2"></i>Excluir
      <% end %>
    <% end %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <%= form_with model: @category, local: true, class: "needs-validation", novalidate: true do |f| %>
      <% if @category.errors.any? %>
        <div class="alert alert-danger">
          <h5><i class="fas fa-exclamation-triangle me-2"></i>Erro ao salvar categoria:</h5>
          <ul class="mb-0">
            <% @category.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :name, "Nome", class: "form-label" %>
        <%= f.text_field :name, class: "form-control", required: true %>
        <div class="invalid-feedback">
          Por favor, informe o nome da categoria.
        </div>
      </div>

      <div class="mb-3">
        <%= f.label :description, "Descrição", class: "form-label" %>
        <%= f.text_area :description, class: "form-control", rows: 3 %>
        <div class="form-text">Descrição opcional da categoria.</div>
      </div>

      <div class="d-flex justify-content-end gap-2">
        <%= link_to category_path(@category), class: "btn btn-secondary" do %>
          <i class="fas fa-times me-2"></i>Cancelar
        <% end %>
        <%= f.submit "Atualizar Categoria", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
