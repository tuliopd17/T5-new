<% content_for :title, "Categorias" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">
    <i class="fas fa-tags me-2"></i>
    Categorias
  </h1>
  <% if current_user&.admin? %>
    <%= link_to new_category_path, class: "btn btn-primary" do %>
      <i class="fas fa-plus me-2"></i>Nova Categoria
    <% end %>
  <% end %>
</div>

<div class="card">
  <div class="card-body">
    <% if @categories.any? %>
      <div class="row">
        <% @categories.each do |category| %>
          <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100">
              <div class="card-body">
                <h5 class="card-title">
                  <%= link_to category.name, category_path(category), class: "text-decoration-none" %>
                </h5>
                <% if category.description.present? %>
                  <p class="card-text">
                    <%= truncate(category.description, length: 100) %>
                  </p>
                <% end %>
                <p class="card-text">
                  <small class="text-muted">
                    <i class="fas fa-book me-1"></i>
                    <%= pluralize(category.books.count, 'livro', 'livros') %>
                  </small>
                </p>
              </div>
              <div class="card-footer bg-transparent">
                <div class="btn-group w-100" role="group">
                  <%= link_to category_path(category), class: "btn btn-outline-primary btn-sm" do %>
                    <i class="fas fa-eye"></i>
                  <% end %>
                  <% if current_user&.admin? %>
                    <%= link_to edit_category_path(category), class: "btn btn-outline-warning btn-sm" do %>
                      <i class="fas fa-edit"></i>
                    <% end %>
                    <%= link_to category_path(category), data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir esta categoria?" },
                        class: "btn btn-outline-danger btn-sm" do %>
                      <i class="fas fa-trash"></i>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="fas fa-tags fa-3x text-muted mb-3"></i>
        <h4 class="text-muted">Nenhuma categoria encontrada</h4>
        <p class="text-muted">Cadastre a primeira categoria do sistema.</p>
        <% if current_user&.admin? %>
          <%= link_to new_category_path, class: "btn btn-primary" do %>
            <i class="fas fa-plus me-2"></i>Cadastrar Categoria
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
